        <activity
            android:name=".EditProfileActivity"
            android:exported="true" />

        <activity
            android:name=".EditSosContactActivity"
            android:exported="true" />

        <activity
            android:name=".PoliceStationActivity"
            android:exported="true" />

        <activity
            android:name=".HospitalActivity"
            android:exported="true" />

        <activity
            android:name=".MedicalShopActivity"
            android:exported="true" />

        <activity
            android:name=".AboutUsActivity"
            android:exported="true" />

        <activity
            android:name=".SafetyTipsActivity"
            android:exported="true" />

        <activity
            android:name=".LanguageActivity"
            android:exported="true" />

    </application>

</manifest>