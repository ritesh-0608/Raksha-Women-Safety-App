<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main Light Theme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_red</item>
        <item name="colorPrimaryDark">@color/primary_red_dark</item>
        <item name="colorAccent">@color/primary_pink</item>
        <item name="android:statusBarColor">@color/primary_red_dark</item>
        <item name="android:windowBackground">@color/accent_white</item>
    </style>

    <!-- Dark Theme -->
    <style name="AppThemeDark" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/primary_red</item>
        <item name="colorPrimaryDark">@color/primary_red_dark</item>
        <item name="colorAccent">@color/primary_pink</item>
        <item name="android:statusBarColor">@color/primary_red_dark</item>
        <item name="android:windowBackground">#121212</item>
    </style>

    <!-- Button Styles -->
    <style name="PrimaryButton">
        <item name="android:background">@drawable/button_primary_bg</item>
        <item name="android:textColor">@color/accent_white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="SecondaryButton">
        <item name="android:background">@drawable/button_secondary_bg</item>
        <item name="android:textColor">@color/primary_red</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Text Styles -->
    <style name="HeadingLarge">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/accent_black</item>
    </style>

    <style name="HeadingMedium">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/accent_black</item>
    </style>

    <style name="BodyText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/accent_dark_gray</item>
    </style>

    <style name="SmallText">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/accent_medium_gray</item>
    </style>

    <!-- EditText Styles -->
    <style name="EditTextStyle">
        <item name="android:background">@drawable/edittext_bg</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/accent_black</item>
        <item name="android:textColorHint">@color/accent_dark_gray</item>
    </style>

    <!-- Card Styles -->
    <style name="CardStyle">
        <item name="android:background">@drawable/card_bg</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>
</resources>