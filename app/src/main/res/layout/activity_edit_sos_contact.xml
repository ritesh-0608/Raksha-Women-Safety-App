<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/accent_white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary_red"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sos_contact_info"
            android:textColor="@color/accent_white"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Current SOS Contact Card -->
            <LinearLayout
                android:id="@+id/current_contact_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Current SOS Contact"
                    style="@style/HeadingMedium"
                    android:layout_marginBottom="12dp" />

                <!-- Contact Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Name:"
                        style="@style/BodyText"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/contact_name_display"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Name"
                        style="@style/BodyText"
                        android:textColor="@color/primary_red" />

                </LinearLayout>

                <!-- Contact Phone -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Phone:"
                        style="@style/BodyText"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/contact_phone_display"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Phone"
                        style="@style/BodyText"
                        android:textColor="@color/primary_red" />

                </LinearLayout>

            </LinearLayout>

            <!-- Info Text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose a contact from your phone to set as your SOS emergency contact. This person will receive your emergency alert when you tap SOS."
                style="@style/BodyText"
                android:layout_marginBottom="24dp"
                android:lineSpacingMultiplier="1.5" />

            <!-- Select Contact Button -->
            <Button
                android:id="@+id/select_contact_btn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Select From Contacts"
                android:textColor="@color/accent_white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/button_primary_bg"
                android:layout_marginBottom="12dp" />

            <!-- Delete Contact Button -->
            <Button
                android:id="@+id/delete_contact_btn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Delete SOS Contact"
                android:textColor="@color/error_red"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/button_secondary_bg" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>