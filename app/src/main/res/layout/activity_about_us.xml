<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/accent_white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary_red"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_us"
            android:textColor="@color/accent_white"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:text="🛡️"
                    android:textSize="60sp"
                    android:gravity="center" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_title"
                style="@style/HeadingLarge"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_description"
                style="@style/BodyText"
                android:layout_marginBottom="24dp"
                android:lineSpacingMultiplier="1.5" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/accent_medium_gray"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Key Features:"
                style="@style/HeadingMedium"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• One-tap SOS Emergency Alert\n• Location Sharing\n• Emergency Contacts\n• Nearby Resources\n• Safety Tips &amp; Education\n• Secure Database\n• User Privacy Focused"
                style="@style/BodyText"
                android:layout_marginBottom="24dp"
                android:lineSpacingMultiplier="1.8" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/accent_medium_gray"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Version: 1.0"
                style="@style/SmallText"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="© 2026 Raksha Safety App\nAll Rights Reserved"
                style="@style/SmallText"
                android:gravity="center" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>