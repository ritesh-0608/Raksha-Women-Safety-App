<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/accent_light_gray">

    <!-- Header with App Name and Moto -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_red"
        android:padding="16dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/accent_white"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_tagline"
            android:textSize="12sp"
            android:textColor="@color/accent_white" />

        <ImageButton
            android:id="@+id/menu_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_more"
            android:scaleType="centerInside"
            android:contentDescription="Menu"
            android:layout_marginTop="8dp"
            android:tint="@color/accent_white" />

    </LinearLayout>

    <!-- SOS Button in Circle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:gravity="center">

        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/sos_button_bg">

            <ImageButton
                android:id="@+id/sos_btn"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/sos_button_bg"
                android:src="@android:drawable/ic_dialog_alert"
                android:scaleType="centerInside"
                android:contentDescription="SOS Button"
                android:layout_gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="SOS"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/accent_black"
                android:gravity="center"
                android:layout_gravity="center" />

        </FrameLayout>

    </LinearLayout>

    <!-- Features -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Helpline Card -->
            <LinearLayout
                android:id="@+id/helpline_card"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/card_bg"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="📞"
                    android:textSize="30sp"
                    android:gravity="center"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/women_helpline"
                        style="@style/HeadingMedium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/helpline_number"
                        style="@style/SmallText" />

                </LinearLayout>

            </LinearLayout>

            <!-- Location Card -->
            <LinearLayout
                android:id="@+id/location_card"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/card_bg"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="📍"
                    android:textSize="30sp"
                    android:gravity="center"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/quick_share_location"
                        style="@style/HeadingMedium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share your live location"
                        style="@style/SmallText" />

                </LinearLayout>

            </LinearLayout>

            <!-- Messages Card -->
            <LinearLayout
                android:id="@+id/messages_card"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/card_bg"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="💡"
                    android:textSize="30sp"
                    android:gravity="center"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/safety_messages"
                        style="@style/HeadingMedium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Get daily safety tips"
                        style="@style/SmallText" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>