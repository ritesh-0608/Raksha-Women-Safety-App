<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/accent_white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary_red"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nearest_police"
            android:textColor="@color/accent_white"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="🚔"
            android:textSize="60sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find nearest police stations"
            style="@style/HeadingMedium"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap the button below to view police stations on map"
            style="@style/BodyText"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/maps_btn"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:text="Open Maps"
            android:textColor="@color/accent_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/button_primary_bg" />

    </LinearLayout>

</LinearLayout>